# Contact form backend — the Cloudflare Worker in workers/contact-email/.
# After `npm run worker:deploy` this is the worker's URL, e.g.
#   https://cabell-contact-email.<your-subdomain>.workers.dev
# For local development run `npm run worker:dev` and use:
#   http://localhost:8787
# Must also be set in the Cloudflare Pages project's environment variables
# (Production scope) so deployed builds get it.
VITE_CONTACT_ENDPOINT=
