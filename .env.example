# Supabase
# Project URL (e.g. https://xxxxx.supabase.co) — used by the JS client AND
# to build the edge function URL for the contact form.
VITE_SUPABASE_URL=

# Anon (publishable) key — safe to expose in the browser bundle. This is
# the public-by-design key, NOT the service-role key. Get it from:
# Supabase dashboard → Project Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=
